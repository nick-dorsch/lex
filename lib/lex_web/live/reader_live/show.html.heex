<div class="reader-container min-h-screen flex flex-col" phx-hook="KeyboardNav" id="reader-container">
  <%= if @loading do %>
      <div class="reader-loading flex-1 flex items-center justify-center">
        <p class="reader-hint text-lg">Loading...</p>
      </div>
  <% else %>
      <%= if @section do %>
        <div class="section-breadcrumb reader-chrome reader-chrome-top fixed top-0 left-0 right-0 min-h-[4.5rem] pt-4 px-4 pb-0 flex flex-col items-start justify-between z-10">
          <div class="w-full flex-1 reader-header-row flex items-center justify-between gap-4">
            <div class="flex items-center gap-2">
              <button
                class="skip-section-btn text-xs px-2 py-1 rounded transition-colors flex items-center gap-1"
                phx-click="navigate_to_library"
                title="Back to Library"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                <span class="hidden sm:inline">Library</span>
              </button>
              <div class="reader-word-counts">
              <span><strong>R</strong> <%= @vocab_counts.read %></span>
              <span><strong>L</strong> <%= @vocab_counts.learning %></span>
              <span><strong>K</strong> <%= @vocab_counts.known %></span>
              </div>
            </div>
            <div class="reader-header-meta">
              <p class="reader-footer-title"><%= @document.title || "Untitled Document" %></p>
              <p class="reader-footer-author"><%= @document.author || "Unknown Author" %></p>
            </div>
            <div class="flex items-center gap-2">
              <button
                class="skip-section-btn text-xs px-2 py-1 rounded transition-colors flex items-center gap-1"
                phx-click="previous_section"
                title="Go to section start"
              >
                <span>↶</span>
                <span class="hidden sm:inline">Previous Section</span>
              </button>
              <button
                class="skip-section-btn text-xs px-2 py-1 rounded transition-colors flex items-center gap-1"
                phx-click="skip_section"
                title="Skip to next section (s key)"
              >
                <span>↷</span>
                <span class="hidden sm:inline">Skip Section</span>
              </button>
            </div>
        </div>
        <!-- Section progress bar -->
        <div class="reader-progress-bar w-[calc(100%+2rem)] -mx-4 h-px overflow-hidden">
          <div class="reader-progress-fill h-full transition-all duration-300 ease-out" style={"width: " <> to_string(@section_progress) <> "%"}></div>
        </div>
      </div>
    <% end %>

    <%= if @sentence do %>
        <!-- LLM Help Popup -->
        <%= if @llm_popup_visible do %>
          <div
            class="llm-popup fixed right-4 top-1/2 z-50 flex w-[22rem] max-h-[70vh] max-w-[calc(100vw-2rem)] -translate-y-1/2 flex-col overflow-hidden rounded-xl max-lg:bottom-24 max-lg:left-4 max-lg:right-4 max-lg:top-auto max-lg:w-auto max-lg:max-h-[40vh] max-lg:translate-y-0"
            data-testid="llm-popup"
            phx-hook="LLMPopup"
            id="llm-popup"
          >
            <div class="llm-popup-header flex items-center justify-between px-4 py-3">
              <span class="llm-popup-title token-learning px-1 py-0.5 rounded text-2xl sm:text-3xl md:text-4xl leading-relaxed font-medium"><strong><%= @llm_popup_word || "Translation Help" %></strong></span>
              <button class="llm-popup-close flex h-7 w-7 items-center justify-center rounded-md text-amber-100/70 transition-colors hover:bg-stone-700/70 hover:text-amber-50" phx-click="dismiss_llm_popup" title="Close (Space)">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              </button>
            </div>
            
            <div class="llm-popup-content min-h-[6rem] flex-1 overflow-y-auto p-4" id="llm-popup-content">
              <%= if @llm_loading do %>
                <div class="llm-popup-loading flex items-center gap-3 py-4 text-sm text-amber-100/80">
                  <div class="llm-popup-spinner h-[18px] w-[18px] shrink-0 animate-spin rounded-full border-2 border-stone-500 border-t-amber-400"></div>
                  <span>Thinking...</span>
                </div>
              <% end %>
              
              <%= if @llm_error do %>
                <div
                  class="llm-popup-error"
                  style="display:flex;align-items:flex-start;gap:0.5rem;padding:0.75rem;border-radius:0.5rem;border:1px solid rgba(248,113,113,0.45);background-color:rgba(239,68,68,0.12);color:#fecaca;font-size:0.875rem;"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                  <span><%= @llm_error %></span>
                </div>
              <% end %>
              
              <%= if @llm_content != "" do %>
                <div class="llm-popup-response text-[0.9375rem] leading-relaxed text-amber-50"><%= raw(@llm_content_html) %></div>
              <% end %>
            </div>
            
          </div>
        <% end %>

        <div class="reading-area flex-1 overflow-hidden px-4">
          <div class="reader-sentence-stage w-full max-w-4xl h-full mx-auto overflow-hidden">
            <!-- Previous sentence (muted, smaller) -->
            <div class="prev-sentence reader-context-sentence reader-context-prev text-lg text-left w-full leading-relaxed flex flex-col justify-end gap-2">
            <%= for sentence <- @prev_sentences do %>
              <p><%= sentence.text %></p>
            <% end %>
            <%= for _ <- List.duplicate(nil, max(0, @context_sentence_count - length(@prev_sentences))) do %>
              <p class="opacity-0">.</p>
            <% end %>
            </div>

            <!-- Current sentence (prominent, full size) -->
            <div class="current-sentence reader-current-sentence text-2xl sm:text-3xl md:text-4xl text-left w-full leading-relaxed font-medium">
              <div class="tokens-container flex flex-wrap justify-start gap-x-1 gap-y-2">
                <%= for {token, index} <- Enum.with_index(@tokens, 1) do %>
                <% lexeme_state = Map.get(@lexeme_states, token.lexeme_id)
                   token_status = lexeme_state && lexeme_state.status
                   is_selectable = not token.is_punctuation
                   is_focused = @focused_token_index == index
                   status_class =
                     cond do
                       not is_selectable -> "token-punctuation"
                       token_status == "learning" -> "token-learning"
                       token_status == "known" -> "token-default"
                       token_status == "seen" -> "token-unseen"
                       true -> "token-default"
                     end

                   focus_class = if is_focused, do: " token-focused", else: ""
                   pointer_class = if is_selectable, do: "cursor-pointer", else: "cursor-default"
                    token_class = "token #{status_class}#{focus_class} #{pointer_class} px-1 py-0.5 rounded transition-colors duration-75"
                  %>
                <span
                  class={token_class}
                  phx-click={if is_selectable, do: "focus_token", else: nil}
                  phx-value-token_index={if is_selectable, do: index, else: nil}
                  data-token-index={index}
                  data-selectable={to_string(is_selectable)}
                >
                  <%= token.surface %>
                </span>
              <% end %>
            </div>
            </div>

            <!-- Next sentence (muted, smaller) -->
            <div class="next-sentence reader-context-sentence reader-context-next text-lg text-left w-full leading-relaxed flex flex-col gap-2">
            <%= for sentence <- @next_sentences do %>
              <p><%= sentence.text %></p>
            <% end %>
            <%= for _ <- List.duplicate(nil, max(0, @context_sentence_count - length(@next_sentences))) do %>
              <p class="opacity-0">.</p>
            <% end %>
            </div>
          </div>
        </div>

      <div class="reader-controls reader-chrome reader-chrome-bottom fixed bottom-0 left-0 right-0 px-4 pt-0 pb-4 flex flex-col items-start justify-center gap-3">
        <!-- Document progress bar -->
        <div class="reader-progress-bar w-[calc(100%+2rem)] -mx-4 h-px overflow-hidden">
          <div class="reader-progress-fill h-full transition-all duration-300 ease-out" style={"width: " <> to_string(@document_progress) <> "%"}></div>
        </div>
        <div class="w-full reader-footer-row flex items-center justify-start gap-3 pt-2">
          <div class="reader-footer-section"><%= @section.title || "Untitled Section" %></div>
          <%= if @focused_token_index > 0 do %>
            <% focused_token = Enum.at(@tokens, @focused_token_index - 1)
               focused_lexeme_state = focused_token && Map.get(@lexeme_states, focused_token.lexeme_id)
               is_learning = focused_lexeme_state && focused_lexeme_state.status == "learning"
            %>
            <button
              class={if is_learning, do: "btn-learning-active px-4 py-2 rounded-lg font-medium transition-colors", else: "btn-learning px-4 py-2 rounded-lg font-medium transition-colors"}
              phx-click="toggle_learning"
            >
              <%= if is_learning, do: "Mark Known", else: "Mark Learning" %>
            </button>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="empty-state flex-1 flex items-center justify-center">
        <p class="reader-hint text-lg">No content available for this document.</p>
      </div>
    <% end %>
  <% end %>
</div>
