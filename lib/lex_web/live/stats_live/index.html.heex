<div class="stats-container">
  <div class="stats-header">
    <h1>Stats</h1>
    <.link navigate={~p"/library"} class="header-link-btn" aria-label="Library" title="Library">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      <span class="sr-only">Library</span>
    </.link>
  </div>

  <div class="stats-cards">
    <div class="stats-card">
      <p class="stats-label">Words - Read</p>
      <p class="stats-value"><%= @counts.words_read %></p>
    </div>
    <div class="stats-card">
      <p class="stats-label">Lex. - Read</p>
      <p class="stats-value"><%= @counts.read %></p>
    </div>
    <div class="stats-card">
      <p class="stats-label">Lex. - Learning</p>
      <p class="stats-value"><%= @counts.learning %></p>
    </div>
    <div class="stats-card">
      <p class="stats-label">Lex. - Known</p>
      <p class="stats-value"><%= @counts.known %></p>
    </div>
  </div>

  <div class="stats-chart-panel">
    <div class="stats-chart-header">
      <h2>Lexemes Timeline</h2>
      <div class="stats-legend">
        <span><i class="legend-dot read"></i>Read</span>
        <span><i class="legend-dot learning"></i>Learning</span>
        <span><i class="legend-dot known"></i>Known</span>
      </div>
    </div>

    <%= if Enum.empty?(@timeline) do %>
      <p class="stats-empty">No reading activity yet.</p>
    <% else %>
      <svg viewBox="0 0 820 260" class="stats-chart" role="img" aria-label="Lexeme growth chart">
        <%= for line <- @chart.grid_lines do %>
          <line x1="56" y1={line.y} x2="804" y2={line.y} class="grid-line" />
          <text x="8" y={line.y + 4} class="grid-label"><%= line.value %></text>
        <% end %>

        <polyline points={@chart.read} class="series read" />
        <polyline points={@chart.learning} class="series learning" />
        <polyline points={@chart.known} class="series known" />

      </svg>

      <h3>Proportions</h3>

      <svg
        viewBox="0 0 820 160"
        class="stats-chart stats-chart-proportions"
        role="img"
        aria-label="Lexeme proportion chart"
      >
        <%= for line <- @proportion_chart.grid_lines do %>
          <line x1="56" y1={line.y} x2="804" y2={line.y} class="grid-line" />
          <text x="8" y={line.y + 4} class="grid-label"><%= line.value %></text>
        <% end %>

        <polyline points={@proportion_chart.read} class="series read" />
        <polyline points={@proportion_chart.learning} class="series learning" />
        <polyline points={@proportion_chart.known} class="series known" />

        <text x="56" y="150" class="axis-label"><%= @chart.labels.start %></text>
        <text x="804" y="150" text-anchor="end" class="axis-label"><%= @chart.labels.end %></text>
      </svg>
    <% end %>
  </div>

  <div class="stats-books-grid">
    <div class="stats-books-panel">
      <h2>In Progress</h2>
      <%= if Enum.empty?(@books_in_progress) do %>
        <p class="stats-empty">No books in progress.</p>
      <% else %>
        <%= for book <- @books_in_progress do %>
          <div class="book-progress-row">
            <p class="book-title"><%= book.title %></p>
            <p class="book-meta"><%= book.read_sentences %>/<%= book.total_sentences %> sentences</p>
            <div class="book-progress-bar">
              <div class="book-progress-fill" style={"width: #{book.progress}%"}></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="stats-books-panel">
      <h2>Completed</h2>
      <%= if Enum.empty?(@books_completed) do %>
        <p class="stats-empty">No books completed yet.</p>
      <% else %>
        <%= for book <- @books_completed do %>
          <div class="book-completed-row">
            <p class="book-title"><%= book.title %></p>
            <p class="book-meta"><%= book.total_sentences %> sentences read</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="stats-learning-panel">
    <h2>Currently Learning</h2>
    <%= if Enum.empty?(@learning_lexemes) do %>
      <p class="stats-empty">No learning lexemes yet.</p>
    <% else %>
      <div class="stats-learning-table-wrap">
        <% learning_table_headers = ["Lemma", "Seen Count", "Document", "Most Recent Sentence", "First Seen"] %>
        <table class="stats-learning-table">
          <thead>
            <tr>
              <%= for header <- learning_table_headers do %>
                <th><%= header %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <%= for item <- @learning_lexemes do %>
              <tr
                class="learning-row"
                phx-click="toggle_learning_row"
                phx-value-lexeme-id={item.lexeme_id}
              >
                <td><%= item.normalized_lemma %></td>
                <td><%= item.seen_count %></td>
                <td><%= item.recent_document_title || "-" %></td>
                <td>
                  <div class="sentence-cell">
                    <span class={[
                      "chevron",
                      @expanded_learning_lexeme_id == item.lexeme_id && "expanded"
                    ]}>
                      ▸
                    </span>
                    <span><%= highlight_sentence_token(item.recent_sentence, item.recent_token_surface) %></span>
                  </div>
                </td>
                <td>
                  <%= if item.first_seen_at do %>
                    <%= Calendar.strftime(item.first_seen_at, "%m/%d/%Y") %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>

              <%= if @expanded_learning_lexeme_id == item.lexeme_id and item.llm_response_text do %>
                <tr class="learning-response-row">
                  <td colspan={length(learning_table_headers)}>
                    <div class="learning-response-content">
                      <div class="learning-response-lemma">
                        <span class="response-lemma-highlight text-2xl sm:text-3xl md:text-4xl leading-none font-medium"><%= item.normalized_lemma %></span>
                      </div>
                      <%= raw(render_markdown_html(item.llm_response_text)) %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
