# Phoenix / app runtime
SECRET_KEY_BASE=replace_with_generated_secret

# LLM configuration (MVP)
LEX_LLM_PROVIDER=openai
LEX_LLM_MODEL=gpt-4o-mini
LEX_LLM_API_KEY=replace_with_provider_key
LEX_LLM_BASE_URL=https://api.openai.com/v1
LEX_LLM_TIMEOUT_MS=15000
LEX_LLM_MAX_OUTPUT_TOKENS=300
LEX_LLM_TEMPERATURE=0.2

# Optional provider-specific keys (if your client library expects these names)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Language scope (MVP constraints)
LEX_READING_LANGUAGE=es
LEX_EXPLANATION_LANGUAGE=en
